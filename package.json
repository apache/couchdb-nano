{
  "name": "nano",
  "description": "The official CouchDB client for Node.js",
  "module": "./dist/nano-esm.mjs",
  "main": "./dist/nano-cjs.js",
  "types": "./lib/nano.d.ts",
  "license": "Apache-2.0",
  "homepage": "http://github.com/apache/couchdb-nano",
  "repository": "http://github.com/apache/couchdb-nano",
  "version": "12.0.0",
  "author": "Apache CouchDB <dev@couchdb.apache.org> (http://couchdb.apache.org)",
  "keywords": [
    "couchdb",
    "data",
    "request",
    "json",
    "nosql",
    "micro",
    "nano",
    "database"
  ],
  "devDependencies": {
    "@types/node": "^26.1.0",
    "rolldown": "^1.1.4",
    "typescript": "^6.0.3",
    "undici": "^7.28.0"
  },
  "scripts": {
    "test": "tsc lib/nano.d.ts && node --experimental-test-coverage --test ./test/*.test.mjs",
    "build:esm": "npx rolldown --input lib/nano.mjs --file dist/nano-esm.mjs -f esm",
    "build:cjs": "npx rolldown --input lib/nano.mjs --file dist/nano-cjs.js -f cjs",
    "build": "npm run build:esm && npm run build:cjs",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.0"
  },
  "pre-commit": [
    "test"
  ]
}
